# ─────────────────────────────────────────────────────────────
# QA Playground V2 — environment variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── App ─────────────────────────────────────────────────────
# Public base URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (Supabase Postgres) ─────────────────────────────
# Transaction-mode pooler URL — used by Prisma runtime (pgbouncer=true)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Session-mode / direct URL — used by Prisma CLI (migrate, generate, push)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Better Auth ──────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-secret

# Must match NEXT_PUBLIC_APP_URL (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated list of additional trusted origins (production domains)
# Example: https://qaplayground.dev,https://www.qaplayground.dev
TRUSTED_ORIGINS=

# ── Google OAuth ─────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Resend (email) ───────────────────────────────────────────
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Must be a sender address on a domain verified in your Resend dashboard
RESEND_FROM_EMAIL=noreply@yourdomain.com
